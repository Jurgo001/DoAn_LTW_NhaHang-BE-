@model IEnumerable<DoAn_LTW_NhaHang.tblHoaDon>
@{
    ViewBag.Title = "Lịch sử đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <h3 class="fw-bold text-primary mb-4 border-start border-4 border-warning ps-3">
        Lịch sử đơn hàng
    </h3>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center">
            Bạn chưa có đơn hàng nào. <a href="@Url.Action("Index", "Home")" class="fw-bold">Đặt món ngay!</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@item.MaHD</td>

                                <td>
                                    @(item.NgayLap.HasValue ? item.NgayLap.Value.ToString("dd/MM/yyyy HH:mm") : "Đang cập nhật")
                                </td>

                                <td class="text-danger fw-bold">
                                    @(item.TongTien.HasValue ? string.Format("{0:N0} đ", item.TongTien.Value) : "0 đ")
                                </td>

                                <td>
                                    @* Cách 1: Nếu bạn ĐÃ cập nhật Model để có quan hệ với tblTinhTrang *@
                                    @if (item.tblTinhTrang != null)
                                    {
                                        <span class="badge bg-info">@item.tblTinhTrang.TinhTrang</span>
                                    }
                                    else
                                    {
                                        // Cách 2: Fix cứng như cũ (nhưng an toàn hơn với .GetValueOrDefault())
                                        var tt = item.TinhTrang.GetValueOrDefault(1);
                                        if (tt == 1)
                                        { <span class="badge bg-warning text-dark">Chờ xác nhận</span> }
                                        else if (tt == 2)
                                        { <span class="badge bg-primary">Đang chế biến</span> }
                                        else if (tt == 3)
                                        { <span class="badge bg-info">Đang phục vụ</span> }
                                        else if (tt == 4)
                                        { <span class="badge bg-success">Đã thanh toán</span> }
                                        else
                                        { <span class="badge bg-secondary">Đã hủy</span>}
                                    }
                                </td>

                                <td class="text-center">
                                    <a href="@Url.Action("ChiTietDonHang", "User", new { id = item.MaHD })" class="btn btn-sm btn-outline-primary rounded-pill">
                                        Xem <i class="fas fa-arrow-right ms-1"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>