@model IEnumerable<DoAn_LTW_NhaHang.tblVoucher>
@{
    ViewBag.Title = "Đổi quà tặng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --gold-primary: #d4af37;
        --gold-gradient: linear-gradient(135deg, #d4af37 0%, #f3e5ab 100%);
        --dark-text: #2c3e50;
        --card-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    body {
        font-family: 'Poppins', sans-serif;
        background-color: #f8f9fa;
    }

    /* Header Section */
    .page-header {
        position: relative;
        padding-bottom: 20px;
        margin-bottom: 40px;
        border-bottom: 1px solid #eee;
    }

    .page-title {
        font-weight: 700;
        color: var(--dark-text);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Balance Card (Hiển thị điểm) */
    .balance-card {
        background: #2c3e50; /* Màu tối sang trọng */
        color: #fff;
        padding: 10px 25px;
        border-radius: 50px;
        display: inline-flex;
        align-items: center;
        box-shadow: 0 5px 15px rgba(44, 62, 80, 0.3);
    }

        .balance-card i {
            color: #f1c40f;
            margin-right: 10px;
            font-size: 1.2rem;
        }

    .balance-amount {
        font-size: 1.2rem;
        font-weight: 700;
        color: #f3e5ab; /* Vàng nhạt */
    }

    /* Voucher Card Design */
    .voucher-card {
        border: none;
        border-radius: 20px;
        background: #fff;
        transition: all 0.3s ease;
        overflow: hidden;
        position: relative;
        box-shadow: var(--card-shadow);
        height: 100%;
    }

        .voucher-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(212, 175, 55, 0.2);
        }

    /* Phần trên của Card (Trang trí) */
    .voucher-top {
        height: 100px;
        background: var(--gold-gradient);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .voucher-icon-circle {
        width: 60px;
        height: 60px;
        background: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold-primary);
        font-size: 1.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        z-index: 2;
        margin-top: 50px; /* Đẩy xuống giữa 2 phần */
    }

    .voucher-body {
        padding: 40px 20px 25px; /* Padding top lớn để né cái icon */
        text-align: center;
    }

    .voucher-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--dark-text);
        margin-bottom: 5px;
    }

    .voucher-value {
        font-size: 0.9rem;
        color: #7f8c8d;
        margin-bottom: 15px;
    }

    .points-tag {
        background-color: #fff8e1;
        color: #d4af37;
        padding: 5px 15px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 1.2rem;
        display: inline-block;
        margin-bottom: 15px;
        border: 1px solid #ffe082;
    }

    .voucher-meta {
        font-size: 0.8rem;
        color: #95a5a6;
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
        border-top: 1px dashed #eee;
        padding-top: 10px;
    }

    /* Button Style */
    .btn-doi-premium {
        background: #2c3e50;
        color: #fff;
        border: none;
        padding: 12px;
        width: 100%;
        border-radius: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s;
    }

        .btn-doi-premium:hover {
            background: var(--gold-primary);
            color: #fff;
            box-shadow: 0 5px 15px rgba(212, 175, 55, 0.4);
        }

        .btn-doi-premium:disabled {
            background: #bdc3c7;
            cursor: not-allowed;
        }

    /* Badge "Hết hàng" */
    .sold-out-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255,255,255,0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
        font-size: 1.5rem;
        font-weight: bold;
        color: #e74c3c;
        transform: rotate(-15deg);
    }
</style>

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center page-header">
        <div>
            <h2 class="page-title"><i class="fas fa-gift text-warning me-2"></i> Thư viện quà tặng</h2>
            <p class="text-muted m-0">Đổi điểm tích lũy lấy ưu đãi độc quyền.</p>
        </div>

        <div class="mt-3 mt-md-0">
            <div class="balance-card">
                <i class="fas fa-coins"></i>
                <span>Số dư khả dụng:&nbsp;</span>
                <span class="balance-amount">@ViewBag.DiemHienTai Điểm</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            // Kiểm tra xem khách có đủ điểm đổi món này không
            bool duDiem = (int)ViewBag.DiemHienTai >= item.DiemDoi;
            bool conHang = item.SoLuong > 0;

            <div class="col-md-6 col-lg-4">
                <div class="voucher-card position-relative">

                    @if (!conHang)
                    {
                        <div class="sold-out-overlay">HẾT HÀNG</div>
                    }

                    <div class="voucher-top">
                        <div class="voucher-icon-circle">
                            <i class="fas fa-ticket-alt"></i>
                        </div>
                    </div>

                    <div class="voucher-body">
                        <h5 class="voucher-title">@item.TenVoucher</h5>
                        <div class="voucher-value">Giá trị: <span class="fw-bold text-dark">@string.Format("{0:0,0} đ", item.GiaTri)</span></div>

                        <div class="points-tag">
                            @item.DiemDoi <small style="font-size: 0.7rem; color: #d4af37;">POINTS</small>
                        </div>

                        <div class="voucher-meta">
                            <span><i class="fas fa-box-open me-1"></i> Còn: <b>@item.SoLuong</b></span>
                            <span><i class="far fa-clock me-1"></i> HSD: @string.Format("{0:dd/MM}", item.NgayHetHan)</span>
                        </div>

                        @if (conHang)
                        {
                            if (duDiem)
                            {
                                <button class="btn-doi-premium btn-doi" data-id="@item.MaVoucher">
                                    Đổi Quà Ngay <i class="fas fa-arrow-right ms-2"></i>
                                </button>
                            }
                            else
                            {
                                <button class="btn-doi-premium" disabled style="background-color: #eee; color: #999;">
                                    Không đủ điểm <i class="fas fa-lock ms-2"></i>
                                </button>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    $(document).ready(function () {
        $('.btn-doi').click(function () {
            var btn = $(this);
            var id = btn.data('id');

            // Dùng SweetAlert2 cho sang
            Swal.fire({
                title: 'Xác nhận đổi quà?',
                text: "Bạn sẽ bị trừ điểm tương ứng để lấy Voucher này.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#d4af37', // Màu vàng gold
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Đồng ý đổi!',
                cancelButtonText: 'Suy nghĩ lại'
            }).then((result) => {
                if (result.isConfirmed) {

                    // Hiện loading
                    Swal.fire({
                        title: 'Đang xử lý...',
                        didOpen: () => { Swal.showLoading() }
                    });

                    $.ajax({
                        url: '/User/ThucHienDoiVoucher',
                        type: 'POST',
                        data: { maVoucher: id },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire(
                                    'Thành công!',
                                    res.msg,
                                    'success'
                                ).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire(
                                    'Thất bại!',
                                    res.msg,
                                    'error'
                                );
                            }
                        },
                        error: function () {
                            Swal.fire('Lỗi!', 'Không thể kết nối đến server.', 'error');
                        }
                    });
                }
            })
        });
    });
</script>