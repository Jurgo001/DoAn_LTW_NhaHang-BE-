@{
    ViewBag.Title = "Đăng nhập";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}

<style>
    /* Ẩn thanh cuộn thừa */
    body {
        overflow-x: hidden;
    }

    .login-container {
        min-height: 100vh;
        background-color: #ffffff;
    }

    /* --- CỘT TRÁI: ẢNH --- */
    .login-image-side {
        background-image: url('https://images.unsplash.com/photo-1540189549336-e6e99c3679fe?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80');
        background-size: cover;
        background-position: center;
        position: relative;
        min-height: 100vh;
    }

    /* Lớp phủ màu để chữ nổi bật hơn */
    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7));
    }

    .login-welcome-text {
        position: absolute;
        bottom: 50px;
        left: 50px;
        color: white;
        z-index: 2;
    }

    /* --- CỘT PHẢI: FORM --- */
    .login-form-side {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
        background-color: #fff;
    }

    .form-wrapper {
        width: 100%;
        max-width: 400px;
    }

    /* Custom Input đẹp hơn */
    .form-floating > .form-control {
        border: none;
        border-bottom: 2px solid #eee;
        border-radius: 0;
        padding-left: 0;
        box-shadow: none !important;
        background: transparent;
    }

        .form-floating > .form-control:focus {
            border-color: #ff6b6b;
        }

    .form-floating > label {
        padding-left: 0;
        color: #999;
    }

    /* Nút đăng nhập */
    .btn-login-modern {
        background: #ff6b6b;
        color: white;
        border-radius: 50px;
        padding: 12px;
        font-weight: bold;
        letter-spacing: 1px;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3);
    }

        .btn-login-modern:hover {
            background: #ee5253;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(238, 82, 83, 0.4);
            color: white;
        }

    /* Nút Social (Facebook/Google - Trang trí) */
    .btn-social {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #eee;
        color: #555;
        transition: 0.2s;
        text-decoration: none;
    }

        .btn-social:hover {
            background-color: #f8f9fa;
            color: #ff6b6b;
        }

    .eye-icon {
        position: absolute;
        right: 10px;
        top: 20px;
        cursor: pointer;
        color: #999;
        z-index: 5;
    }
</style>

<div class="row g-0 login-container">

    <div class="col-lg-7 d-none d-lg-block login-image-side">
        <div class="overlay"></div>
        <div class="login-welcome-text">
            <h1 class="display-4 fw-bold">Hương vị tuyệt hảo</h1>
            <p class="lead">Đặt món nhanh chóng, giao hàng tận nơi với Nhà Hàng Ngon.</p>
        </div>
    </div>

    <div class="col-lg-5 login-form-side">
        <div class="form-wrapper">

            <div class="mb-5">
                <h2 class="fw-bold mb-2" style="color: #2d3436;">Xin chào,</h2>
                <p class="text-muted">Đăng nhập để tiếp tục thưởng thức món ngon.</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger rounded-3 fade show">
                    <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error
                </div>
            }
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success border-0 bg-success bg-opacity-10 text-success rounded-3 fade show">
                    <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                </div>
            }

            @using (Html.BeginForm("LoginOnSubMit", "User", FormMethod.Post))
            {
                <div class="form-floating mb-4">
                    <input type="text" class="form-control" id="loginEmail" name="Email" placeholder="name@example.com" required>
                    <label for="loginEmail">Email hoặc Tên đăng nhập</label>
                </div>

                <div class="form-floating mb-4 position-relative">
                    <input type="password" class="form-control" id="loginPassword" name="MatKhau" placeholder="Password" required>
                    <label for="loginPassword">Mật khẩu</label>
                    <i class="fas fa-eye eye-icon" onclick="togglePass()"></i>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="remember">
                        <label class="form-check-label small text-secondary" for="remember">Ghi nhớ tôi</label>
                    </div>

                    <a href="@Url.Action("QuenMatKhau", "User")" class="text-decoration-none small text-danger fw-bold">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn btn-login-modern w-100 mb-4">
                    ĐĂNG NHẬP <i class="fas fa-arrow-right ms-2"></i>
                </button>

                <div class="text-center mb-4 position-relative">
                    <hr class="text-secondary opacity-25">
                    <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 small text-muted">Hoặc tiếp tục với</span>
                </div>

                <div class="d-flex justify-content-center gap-3 mb-4">
                    <a href="https://www.facebook.com/login/" class="btn-social"><i class="fab fa-facebook-square"></i></a>
                    <a href="https://www.instagram.com/accounts/login/"  class="btn-social"><i class="fab fa-instagram"></i></a>
                    <a href="https://www.tiktok.com/login"  class="btn-social"><i class="fab fa-tiktok"></i></a>
                </div>

                <div class="text-center">
                    <span class="text-muted">Chưa có tài khoản?</span>
                    <a href="@Url.Action("Register", "User")" class="text-decoration-none fw-bold text-danger ms-1">Tạo tài khoản mới</a>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function togglePass() {
        const input = document.getElementById('loginPassword');
        const icon = document.querySelector('.eye-icon');

        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
            icon.style.color = "#ff6b6b";
        } else {
            input.type = "password";
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
            icon.style.color = "#999";
        }
    }
</script>