@model DoAn_LTW_NhaHang.Models.ThongKeViewModel

@{
    ViewBag.Title = "Báo Cáo Doanh Thu";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    
    // Tạo chuỗi dữ liệu JSON để vẽ biểu đồ
    var labels = Newtonsoft.Json.JsonConvert.SerializeObject(Model.DoanhThuTheoNgay.Select(x => x.Ngay.ToString("dd/MM")));
    var data = Newtonsoft.Json.JsonConvert.SerializeObject(Model.DoanhThuTheoNgay.Select(x => x.DoanhThu));
}

<style>
    .card-stat {
        border: none;
        border-radius: 15px;
        transition: transform 0.3s;
        color: white;
        overflow: hidden;
        position: relative;
    }
    .card-stat:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }
    .bg-gradient-primary {
        background: linear-gradient(45deg, #ff6b6b, #ff9f43);
    }
    .bg-gradient-success {
        background: linear-gradient(45deg, #1dd1a1, #10ac84);
    }
    .bg-gradient-warning {
        background: linear-gradient(45deg, #feca57, #ff9f43);
    }
    
    .circle-icon {
        position: absolute;
        right: -20px;
        bottom: -20px;
        font-size: 8rem;
        opacity: 0.2;
        transform: rotate(-15deg);
    }

    .table-custom thead th {
        background-color: #fff0f0;
        color: #ff6b6b;
        border-bottom: 2px solid #ff6b6b;
    }
    
    .rank-badge {
        width: 30px;
        height: 30px;
        background: #eee;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: #555;
    }
    .rank-1 { background: #ffd700; color: #fff; box-shadow: 0 2px 5px rgba(255, 215, 0, 0.4); }
    .rank-2 { background: #c0c0c0; color: #fff; }
    .rank-3 { background: #cd7f32; color: #fff; }
</style>

<div class="container-fluid py-4">
    
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="fw-bold m-0 text-dark">Thống Kê Kinh Doanh</h3>
            <p class="text-muted small m-0">Tổng hợp số liệu kinh doanh của nhà hàng</p>
        </div>

        <div class="bg-white p-2 rounded-pill shadow-sm border d-flex align-items-center">
            <form action="@Url.Action("ThongKe", "Admin")" method="get" class="d-flex align-items-center gap-2">
                <input type="date" name="fromDate" value="@ViewBag.Start" class="form-control form-control-sm border-0 bg-light rounded-pill px-3" />
                <span class="text-muted"><i class="fas fa-arrow-right small"></i></span>
                <input type="date" name="toDate" value="@ViewBag.End" class="form-control form-control-sm border-0 bg-light rounded-pill px-3" />
                <button type="submit" class="btn btn-primary btn-sm rounded-pill px-3">
                    <i class="fas fa-filter me-1"></i> Lọc
                </button>
            </form>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6 col-lg-6">
            <div class="card card-stat bg-gradient-primary h-100 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="text-uppercase mb-2 opacity-75">Tổng Doanh Thu (Thực thu)</h6>
                    <h2 class="display-5 fw-bold mb-0">@string.Format("{0:N0}", ViewBag.TongDoanhThu)<span class="fs-4">đ</span></h2>
                    <p class="mb-0 mt-2 small opacity-75"><i class="fas fa-check-circle me-1"></i> Đã thanh toán thành công</p>
                    <i class="fas fa-coins circle-icon"></i>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-6">
            <div class="card card-stat bg-gradient-warning h-100 shadow-sm text-dark">
                <div class="card-body p-4">
                    <h6 class="text-uppercase mb-2 opacity-75 text-white">Đơn Hàng Mới</h6>
                    <h2 class="display-5 fw-bold mb-0 text-white">@ViewBag.DonMoi</h2>
                    <p class="mb-0 mt-2 small opacity-75 text-white"><i class="fas fa-clock me-1"></i> Đang chờ xác nhận</p>
                    <i class="fas fa-receipt circle-icon text-white"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold m-0 text-secondary"><i class="fas fa-chart-area me-2 text-primary"></i>Biểu Đồ Doanh Thu</h5>
                </div>
                <div class="card-body p-4">
                    <canvas id="revenueChart" style="max-height: 350px;"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold m-0 text-secondary"><i class="fas fa-crown me-2 text-warning"></i>Top Món Yêu Thích</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush mt-3">
                        @{ int rank = 1; }
                        @foreach (var item in Model.TopMonAn.Take(5))
                        {
                            <div class="list-group-item border-0 d-flex align-items-center px-4 py-3">
                                <div class="rank-badge me-3 @(rank == 1 ? "rank-1" : rank == 2 ? "rank-2" : rank == 3 ? "rank-3" : "")">
                                    @rank
                                </div>
                                <img src="@Url.Content("~/Content/Images/" + item.HinhAnh)" class="rounded-circle shadow-sm me-3" width="45" height="45" style="object-fit:cover">
                                <div class="flex-grow-1">
                                    <h6 class="m-0 fw-bold text-dark">@item.TenMon</h6>
                                    <small class="text-muted">Đã bán: <b class="text-primary">@item.SoLuongBan</b></small>
                                </div>
                                <div class="text-end">
                                    <small class="d-block text-muted">Doanh thu</small>
                                    <span class="fw-bold text-success">
                                        @string.Format("{0:N0} đ", item.TongTien)
                                    </span>
                                </div>
                            </div>
                            rank++;
                        }
                    </div>
                    <div class="text-center p-3 border-top">
                        <a href="#" class="text-decoration-none small fw-bold text-primary">Xem tất cả <i class="fas fa-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="fw-bold text-secondary"><i class="fas fa-tags me-2 text-info"></i>Thống Kê Theo Loại Món</h5>
                </div>
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-custom align-middle">
                            <thead>
                                <tr>
                                    <th>Tên Loại</th>
                                    <th>Số lượng bán</th>
                                    <th>Doanh thu</th>
                                    <th>Tỉ trọng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ decimal totalRevenue = Model.DoanhThuTheoLoai.Sum(x => x.TongTien); }
                                @foreach (var item in Model.DoanhThuTheoLoai.OrderByDescending(x => x.TongTien))
                                {
                                    decimal percent = totalRevenue > 0 ? (item.TongTien / totalRevenue) * 100 : 0;
                                    <tr>
                                        <td class="fw-bold text-dark">@item.TenLoai</td>
                                        <td>@item.SoLuongBan</td>
                                        <td class="fw-bold text-success">@string.Format("{0:N0}", item.TongTien) đ</td>
                                        <td style="width: 30%">
                                            <div class="d-flex align-items-center">
                                                <span class="me-2 small fw-bold">@percent.ToString("0")%</span>
                                                <div class="progress flex-grow-1" style="height: 6px;">
                                                    <div class="progress-bar bg-gradient-primary" style="width: @percent%"></div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // Lấy dữ liệu từ C# đổ vào JS
    var ctx = document.getElementById('revenueChart').getContext('2d');
    var chartData = {
        labels: @Html.Raw(labels),
        datasets: [{
            label: 'Doanh thu (VNĐ)',
            data: @Html.Raw(data),
            backgroundColor: 'rgba(255, 107, 107, 0.1)', // Màu nền đỏ nhạt
            borderColor: '#ff6b6b', // Màu viền đỏ cam
            borderWidth: 2,
            pointBackgroundColor: '#fff',
            pointBorderColor: '#ff6b6b',
            pointRadius: 4,
            fill: true,
            tension: 0.4 // Làm mềm đường cong
        }]
    };

    var myChart = new Chart(ctx, {
        type: 'line', // Biểu đồ đường
        data: chartData,
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            var value = context.parsed.y;
                            return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(value);
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { borderDash: [5, 5] }
                },
                x: {
                    grid: { display: false }
                }
            }
        }
    });
</script>