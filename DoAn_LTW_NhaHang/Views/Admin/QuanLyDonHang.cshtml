@model IEnumerable<DoAn_LTW_NhaHang.tblHoaDon>

@{
    ViewBag.Title = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    // Lấy giá trị trạng thái đang chọn để active nút
    int? currentStatus = ViewBag.CurrentStatus as int?;
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="fw-bold m-0 text-dark"><i class="fas fa-receipt me-2 text-primary"></i>Quản Lý Đơn Hàng</h3>
            <p class="text-muted small m-0">Xem và cập nhật trạng thái các đơn đặt món</p>
        </div>

        <form action="@Url.Action("QuanLyDonHang", "Admin")" method="get" class="d-flex gap-2">
            @if (currentStatus.HasValue)
            {<input type="hidden" name="status" value="@currentStatus" />}

            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                <input type="text" name="keyword" value="@ViewBag.CurrentKeyword" class="form-control border-start-0 ps-0" placeholder="Tìm theo mã đơn hoặc tên khách...">
            </div>
            <button type="submit" class="btn btn-white shadow-sm border text-primary fw-bold"><i class="fas fa-filter me-1"></i> Lọc</button>

            <a href="@Url.Action("QuanLyDonHang", "Admin")" class="btn btn-light shadow-sm border" title="Xóa lọc"><i class="fas fa-sync-alt text-muted"></i></a>
        </form>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <div class="card-header bg-white border-bottom-0 py-3">
            <ul class="nav nav-pills card-header-pills gap-2 flex-wrap">
                <li class="nav-item">
                    <a class="nav-link rounded-pill @(currentStatus == null ? "active bg-primary" : "text-muted bg-light")"
                       href="@Url.Action("QuanLyDonHang", "Admin")">Tất cả</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link rounded-pill @(currentStatus == 1 ? "active bg-warning text-dark" : "text-muted bg-light")"
                       href="@Url.Action("QuanLyDonHang", "Admin", new { status = 1 })">
                        <i class="fas fa-clock me-1"></i> Chờ xác nhận
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link rounded-pill @(currentStatus == 2 ? "active bg-info text-dark" : "text-muted bg-light")"
                       href="@Url.Action("QuanLyDonHang", "Admin", new { status = 2 })">
                        <i class="fas fa-fire me-1"></i> Đang nấu
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link rounded-pill @(currentStatus == 3 ? "active bg-primary" : "text-muted bg-light")"
                       href="@Url.Action("QuanLyDonHang", "Admin", new { status = 3 })">
                        <i class="fas fa-truck me-1"></i> Đang giao
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link rounded-pill @(currentStatus == 4 ? "active bg-success" : "text-muted bg-light")"
                       href="@Url.Action("QuanLyDonHang", "Admin", new { status = 4 })">
                        <i class="fas fa-check-circle me-1"></i> Hoàn thành
                    </a>
                </li>
            </ul>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="ps-4 py-3">Mã đơn</th>
                        <th class="py-3">Khách hàng</th>
                        <th class="py-3">Ngày đặt</th>
                        <th class="py-3 text-end">Tổng tiền</th>
                        <th class="py-3 text-center">Trạng thái</th>
                        <th class="py-3 text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4"><span class="fw-bold text-primary">#@item.MaHD</span></td>
                                <td>@item.tblKhachHang.TenKH <br><small class="text-muted">@item.tblKhachHang.DienThoai</small></td>
                                <td>@string.Format("{0:dd/MM/yyyy HH:mm}", item.NgayLap)</td>
                                <td class="text-end fw-bold text-success">@string.Format("{0:N0}", item.TongTien) đ</td>

                                <td class="text-center">
                                    @if (item.TinhTrang == 1)
                                    {<span class="badge bg-warning text-dark">Chờ xác nhận</span> }
                                    else if (item.TinhTrang == 2)
                                    { <span class="badge bg-info text-dark">Đang chế biến</span> }
                                    else if (item.TinhTrang == 3)
                                    { <span class="badge bg-primary">Đang giao</span> }
                                    else if (item.TinhTrang == 4)
                                    { <span class="badge bg-success">Hoàn thành</span> }
                                    else
                                    { <span class="badge bg-secondary">Đã hủy</span>}
                                </td>

                                <td class="text-center">
                                    <a href="@Url.Action("DuyetDonHang", new { id = item.MaHD })" class="btn btn-outline-primary btn-sm rounded-pill px-3">Chi tiết <i class="fas fa-arrow-right"></i></a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted">Không tìm thấy đơn hàng nào!</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white border-0 py-3">
            <small class="text-muted">Hiển thị <b>@Model.Count()</b> kết quả</small>
        </div>
    </div>
</div>