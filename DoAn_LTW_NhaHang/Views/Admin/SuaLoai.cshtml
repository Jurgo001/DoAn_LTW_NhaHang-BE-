@model DoAn_LTW_NhaHang.tblLoaiMon

@{
    ViewBag.Title = "Cập nhật loại món";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    /* Custom CSS cho form này */
    .card-edit {
        border-top: 5px solid #ff6b6b !important; /* Viền màu chủ đạo */
        transition: transform 0.3s;
    }

    .icon-header {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #fff0f0 0%, #ffeecf 100%);
        color: #ff6b6b;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        margin: -50px auto 20px auto; /* Đẩy lên trên */
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        font-size: 2rem;
    }

    .form-control:focus {
        border-color: #ff6b6b;
        box-shadow: 0 0 0 0.25rem rgba(255, 107, 107, 0.25);
    }

    .btn-gradient {
        background: linear-gradient(45deg, #ff6b6b, #ff9f43);
        border: none;
        color: white;
        transition: all 0.3s;
    }

        .btn-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 107, 107, 0.4);
            color: white;
        }
</style>

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 card-edit mt-4">

                <div class="card-body p-4 position-relative">
                    <div class="icon-header">
                        <i class="fas fa-edit"></i>
                    </div>

                    <div class="text-center mb-4">
                        <h4 class="fw-bold text-dark">Cập Nhật Loại Món</h4>
                        <p class="text-muted small">Chỉnh sửa thông tin danh mục #@Model.MaLoai</p>
                    </div>

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.MaLoai)

                        <div class="form-floating mb-3">
                            @Html.TextBoxFor(m => m.TenLoai, new { @class = "form-control rounded-3", placeholder = "Tên loại", required = "required" })
                            @Html.LabelFor(m => m.TenLoai, "Tên Loại Món")
                            @Html.ValidationMessageFor(m => m.TenLoai, "", new { @class = "text-danger small ms-2" })
                        </div>

                        <div class="form-floating mb-4">
                            @Html.TextAreaFor(m => m.MoTa, new { @class = "form-control rounded-3", placeholder = "Mô tả", style = "height: 120px" })
                            @Html.LabelFor(m => m.MoTa, "Mô tả chi tiết (Tùy chọn)")
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-gradient rounded-pill py-2 fw-bold fs-6">
                                <i class="fas fa-save me-2"></i> Lưu Thay Đổi
                            </button>

                            <a href="@Url.Action("QuanLyLoai")" class="btn btn-light rounded-pill py-2 text-muted fw-bold">
                                <i class="fas fa-times me-2"></i> Hủy Bỏ
                            </a>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>