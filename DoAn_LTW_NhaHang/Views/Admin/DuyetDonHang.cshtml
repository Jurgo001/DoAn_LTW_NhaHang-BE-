@model DoAn_LTW_NhaHang.tblHoaDon
@{
    ViewBag.Title = "Chi tiết đơn hàng #" + Model.MaHD;
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var listTT = ViewBag.TrangThaiList as List<DoAn_LTW_NhaHang.tblTinhTrang>;
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("QuanLyDonHang", "Admin")" class="text-decoration-none">Quản lý đơn hàng</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết đơn #@Model.MaHD</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-primary m-0"><i class="fas fa-receipt me-2"></i>Danh Sách Món Ăn</h5>
                    <span class="text-muted small"><i class="far fa-clock me-1"></i> @string.Format("{0:dd/MM/yyyy HH:mm}", Model.NgayLap)</span>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-secondary">
                                <tr>
                                    <th class="ps-4 py-3">Món ăn</th>
                                    <th class="text-center py-3">Đơn giá</th>
                                    <th class="text-center py-3">Số lượng</th>
                                    <th class="text-end pe-4 py-3">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ct in Model.tblChiTietHoaDons)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <img src="@Url.Content("~/Content/Images/" + ct.tblMonAn.AnhDaiDien)"
                                                     class="rounded-3 shadow-sm me-3 border"
                                                     width="50" height="50" style="object-fit:cover"
                                                     onerror="this.src='https://via.placeholder.com/50'" />
                                                <div>
                                                    <span class="fw-bold text-dark d-block">@ct.tblMonAn.TenMon</span>
                                                    <small class="text-muted">@(ct.tblMonAn.tblLoaiMon?.TenLoai ?? "Món ăn")</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">@string.Format("{0:N0}", ct.DonGia)</td>
                                        <td class="text-center">
                                            <span class="badge bg-light text-dark border px-2 py-1">x @ct.SoLuong</span>
                                        </td>
                                        <td class="text-end pe-4 fw-bold text-dark">
                                            @string.Format("{0:N0}", ct.DonGia * ct.SoLuong) đ
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="bg-light">
                                <tr>
                                    <td colspan="3" class="text-end py-3 fw-bold text-secondary">Tổng tạm tính:</td>
                                    <td class="text-end pe-4 py-3 fw-bold">@string.Format("{0:N0}", Model.TongTien) đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-secondary text-uppercase mb-3" style="font-size: 0.8rem; letter-spacing: 1px;">Khách hàng</h6>

                    <div class="d-flex align-items-center mb-4">
                        <img src="https://ui-avatars.com/api/?name=@(Model.tblKhachHang.TenKH)&background=random&size=50" class="rounded-circle me-3 shadow-sm">
                        <div>
                            <h6 class="fw-bold m-0">@Model.tblKhachHang.TenKH</h6>
                            <span class="text-muted small"><i class="fas fa-phone-alt me-1"></i> @Model.tblKhachHang.DienThoai</span>
                        </div>
                    </div>

                    <div class="p-3 bg-light rounded-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Mã đơn:</span>
                            <span class="fw-bold">#@Model.MaHD</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Thanh toán:</span>
                            @if (Model.DaThanhToan == true)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success"><i class="fas fa-check me-1"></i> Đã thanh toán</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger"><i class="fas fa-times me-1"></i> Chưa thanh toán</span>
                            }
                        </div>
                        <hr class="my-2 border-secondary opacity-25">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-dark">Tổng cộng:</span>
                            <span class="fs-5 fw-bold text-primary">@string.Format("{0:N0} đ", Model.TongTien)</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white" style="background: linear-gradient(135deg, #ff6b6b 0%, #ff9f43 100%);">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="fas fa-tasks me-2"></i>Cập nhật tiến độ</h5>

                    @using (Html.BeginForm("CapNhatTrangThai", "Admin", FormMethod.Post))
                    {
                        <input type="hidden" name="MaHD" value="@Model.MaHD" />

                        <div class="mb-3">
                            <label class="form-label small text-white-50">Trạng thái hiện tại:</label>
                            <select name="MaTinhTrang" class="form-select form-select-lg border-0 shadow-sm text-primary fw-bold">
                                @foreach (var tt in listTT)
                                {
                                    <option value="@tt.ID" @(Model.TinhTrang == tt.ID ? "selected" : "")>
                                        @tt.TinhTrang
                                    </option>
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn btn-light w-100 fw-bold text-primary shadow-sm py-2 mb-3">
                            <i class="fas fa-save me-1"></i> Lưu Trạng Thái
                        </button>

                        <a href="@Url.Action("QuanLyDonHang")" class="btn btn-outline-light w-100 btn-sm border-0">
                            <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                        </a>
                    }
                </div>
            </div>

        </div>
    </div>
</div>