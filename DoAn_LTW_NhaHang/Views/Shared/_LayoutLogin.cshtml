<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Nhà Hàng Ngon</title>

    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&family=Pacifico&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --primary-color: #ff6b6b;
            --primary-hover: #ee5253;
            --glass-bg: rgba(255, 255, 255, 0.85);
            --glass-border: 1px solid rgba(255, 255, 255, 0.5);
            --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        body {
            font-family: 'Nunito', sans-serif;
            background-color: #ffffff;
            margin: 0;
            padding: 0;
            opacity: 0;
            animation: fadeInPage 0.8s ease-out forwards;
        }

        /* --- SỬA LỖI TẠI ĐÂY: DÙNG @@ --- */
        @@keyframes slideDown {
            from {
                transform: translateY(-100%);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .navbar-glass {
            background: var(--glass-bg) !important;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: var(--glass-border);
            box-shadow: var(--shadow-soft);
            padding-top: 15px;
            padding-bottom: 15px;
            animation: slideDown 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
        }

        .navbar-brand {
            font-family: 'Pacifico', cursive;
            color: var(--primary-color) !important;
            font-size: 1.8rem;
            text-shadow: 2px 2px 0px rgba(255, 107, 107, 0.1);
            transition: transform 0.3s;
        }

            .navbar-brand:hover {
                transform: scale(1.05) rotate(-2deg);
            }

        .nav-link {
            font-weight: 700;
            color: #555 !important;
            margin: 0 12px;
            position: relative;
            padding-bottom: 5px;
            transition: color 0.3s;
        }

            .nav-link::after {
                content: '';
                position: absolute;
                width: 0;
                height: 2px;
                bottom: 0;
                left: 0;
                background-color: var(--primary-color);
                transition: width 0.3s ease-in-out;
            }

            .nav-link:hover {
                color: var(--primary-color) !important;
            }

                .nav-link:hover::after {
                    width: 100%;
                }

        .btn-premium {
            background: linear-gradient(45deg, #ff6b6b, #ff9f43);
            color: white !important;
            border: none;
            border-radius: 50px;
            padding: 8px 25px;
            font-weight: 700;
            letter-spacing: 0.5px;
            box-shadow: 0 4px 15px rgba(255, 107, 107, 0.4);
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            z-index: 1;
        }

            .btn-premium::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: linear-gradient(45deg, #ff9f43, #ff6b6b);
                opacity: 0;
                z-index: -1;
                transition: opacity 0.4s ease;
            }

            .btn-premium:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 25px rgba(255, 107, 107, 0.6);
            }

                .btn-premium:hover::before {
                    opacity: 1;
                }

        /* --- SỬA LỖI TẠI ĐÂY: DÙNG @@ --- */
        @@media (max-width: 991px) {
            .navbar-collapse {
                background: white;
                padding: 20px;
                border-radius: 15px;
                margin-top: 10px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            }

            .btn-premium {
                display: block;
                text-align: center;
                margin-top: 10px;
                width: 100%;
            }

            .nav-item.ms-3 {
                margin-left: 0 !important;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg fixed-top navbar-glass">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("TrangChu", "Home")">
                <i class="fas fa-utensils me-2"></i>Nhà Hàng Ngon
            </a>
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navLogin">
                <span class="fas fa-bars text-dark fs-4"></span>
            </button>
            <div class="collapse navbar-collapse" id="navLogin">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("TrangChu", "Home")">Trang Chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Home")">Thực Đơn</a></li>
                    @{ string currentAction = ViewContext.RouteData.Values["action"].ToString(); }
                    @if (currentAction != "Register")
                    {
                        <li class="nav-item ms-3">
                            <a href="@Url.Action("Register", "User")" class="btn-premium">Đăng Ký Ngay <i class="fas fa-arrow-right ms-2 small"></i></a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-3">
                            <a href="@Url.Action("Login", "User")" class="btn-premium">Đăng Nhập <i class="fas fa-sign-in-alt ms-2 small"></i></a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @RenderBody()

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>