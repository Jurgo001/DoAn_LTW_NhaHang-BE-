@{
    ViewBag.Title = "Liên Hệ";
    Layout = "~/Views/Shared/_LayoutLienHe.cshtml";
}

<style>
    .contact-wrapper {
        width: 100%;
        overflow-x: hidden;
    }

    /* Banner */
    .contact-banner {
        position: relative;
        width: 100%;
        height: 350px;
        background: url('https://images.unsplash.com/photo-1559339352-11d035aa65de?auto=format&fit=crop&w=1920&q=80') center center / cover no-repeat;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .banner-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.5); /* Lớp phủ đen mờ */
    }

    /* Card Chính */
    .main-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
        overflow: hidden;
        margin-top: -80px; /* Đẩy lên trên banner */
        position: relative;
        z-index: 10;
        max-width: 1100px; /* Giới hạn chiều rộng để đẹp hơn */
        margin-left: auto; /* Căn giữa */
        margin-right: auto; /* Căn giữa */
    }

    /* Cột Trái */
    .info-side {
        background-color: #2d3436;
        color: white;
        padding: 50px;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* Cột Phải */
    .form-side {
        padding: 50px;
        background-color: white;
    }

    .form-control {
        background-color: #f8f9fa;
        border: 1px solid #eee;
        padding: 12px;
        border-radius: 8px;
    }

        .form-control:focus {
            border-color: #ff6b6b;
            box-shadow: none;
            background-color: #fff;
        }

    .btn-submit {
        background-color: #ff6b6b;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 50px;
        width: 100%;
        font-weight: bold;
        font-size: 1.1rem;
        transition: 0.3s;
    }

        .btn-submit:hover {
            background-color: #ff4757;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 107, 107, 0.3);
        }
</style>

<div class="contact-wrapper">

    <div class="contact-banner">
        <div class="banner-overlay"></div>
        <div class="text-center position-relative text-white z-2">
            <h1 class="fw-bold display-4">Liên Hệ Với Chúng Tôi</h1>
            <p class="fs-5 opacity-75">Sẵn sàng lắng nghe và phục vụ bạn tốt hơn</p>
        </div>
    </div>

    <div class="container pb-5">
        <div class="main-card">
            <div class="row g-0">

                <div class="col-lg-5">
                    <div class="info-side">
                        <h3 class="fw-bold mb-4 border-bottom border-secondary pb-3">Thông Tin</h3>

                        <div class="d-flex mb-4">
                            <div class="me-3 text-danger fs-4"><i class="fas fa-map-marker-alt"></i></div>
                            <div>
                                <h6 class="fw-bold mb-1">Địa chỉ</h6>
                                <p class="text-white-50 mb-0">140 Lê Trọng Tấn, P. Tây Thạnh, Q. Tân Phú, TP.HCM</p>
                            </div>
                        </div>

                        <div class="d-flex mb-4">
                            <div class="me-3 text-danger fs-4"><i class="fas fa-phone-alt"></i></div>
                            <div>
                                <h6 class="fw-bold mb-1">Hotline</h6>
                                <p class="text-white-50 mb-0">0909 736 426</p>
                            </div>
                        </div>

                        <div class="d-flex mb-4">
                            <div class="me-3 text-danger fs-4"><i class="fas fa-envelope"></i></div>
                            <div>
                                <h6 class="fw-bold mb-1">Email</h6>
                                <p class="text-white-50 mb-0">cskh@nhahangngon.vn</p>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="form-side">
                        <h3 class="fw-bold mb-4 text-dark">Gửi Tin Nhắn</h3>
                        <form id="contactForm">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="small fw-bold text-secondary mb-1">Họ tên</label>
                                    <input type="text" class="form-control" name="hoTen" required placeholder="Nhập tên của bạn">
                                </div>
                                <div class="col-md-6">
                                    <label class="small fw-bold text-secondary mb-1">Email</label>
                                    <input type="email" class="form-control" name="email" required placeholder="email@vidu.com">
                                </div>
                                <div class="col-12">
                                    <label class="small fw-bold text-secondary mb-1">Số điện thoại</label>
                                    <input type="tel" class="form-control" name="sdt" required placeholder="Số điện thoại liên hệ">
                                </div>
                                <div class="col-12">
                                    <label class="small fw-bold text-secondary mb-1">Chủ đề</label>
                                    <select class="form-select form-control" name="chuDe">
                                        <option>Góp ý món ăn</option>
                                        <option>Thái độ phục vụ</option>
                                        <option>Đặt tiệc</option>
                                        <option selected>Khác</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="small fw-bold text-secondary mb-1">Nội dung</label>
                                    <textarea class="form-control" rows="4" name="noiDung" required placeholder="Nội dung tin nhắn..."></textarea>
                                </div>
                                <div class="col-12 mt-4">
                                    <button type="submit" class="btn-submit" id="btnSubmit">
                                        <i class="fas fa-paper-plane me-2"></i> Gửi Ngay
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>

        <div class="mt-5 shadow-sm rounded-4 overflow-hidden" style="max-width: 1100px; margin: 30px auto 0;">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.062402123769!2d106.6263433748053!3d10.806532989344053!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752be27d8b4f4d%3A0x92dcba2950430867!2zMTQwIEzDqiBUcuG7jW5nIFThuqVuLCBUw6J5IFRo4bqhbmgsIFTDom4gUGjDuiwgSOG7kyBDaMOtIE1pbmgsIFZpZXRuYW0!5e0!3m2!1sen!2s!4v1709628000000!5m2!1sen!2s"
                    width="100%" height="400" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
        </div>

    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $(document).ready(function () {
        $('#contactForm').submit(function (e) {
            e.preventDefault();
            var btn = $('#btnSubmit');
            var oldText = btn.html();
            btn.html('<i class="fas fa-spinner fa-spin"></i> Đang gửi...').prop('disabled', true);

            $.ajax({
                url: '/Home/GuiLienHe',
                type: 'POST',
                data: {
                    hoTen: $('input[name="hoTen"]').val(),
                    email: $('input[name="email"]').val(),
                    sdt: $('input[name="sdt"]').val(),
                    chuDe: $('select[name="chuDe"]').val(),
                    noiDung: $('textarea[name="noiDung"]').val()
                },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ title: 'Thành công!', text: res.msg, icon: 'success', confirmButtonColor: '#ff6b6b' });
                        $('#contactForm')[0].reset();
                    } else {
                        Swal.fire('Lỗi', res.msg, 'error');
                    }
                },
                error: function () { Swal.fire('Lỗi mạng', 'Không thể kết nối server', 'error'); },
                complete: function () { btn.html(oldText).prop('disabled', false); }
            });
        });
    });
</script>