@using DoAn_LTW_NhaHang.Models
@model tblMonAn
@{
    ViewBag.Title = "Chi tiết: " + Model.TenMon;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Phần ảnh chính */
    .main-image-container {
        position: relative;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        background: #fff;
    }

    #mainImage {
        width: 100%;
        height: 400px;
        object-fit: cover; /* Đảm bảo ảnh luôn đẹp dù khung hình chữ nhật */
        transition: transform 0.5s ease;
    }

    /* Hiệu ứng zoom nhẹ khi rê chuột vào ảnh lớn */
    .main-image-container:hover #mainImage {
        transform: scale(1.05);
    }

    /* Thumbnails */
    .thumb-wrapper {
        display: flex;
        gap: 10px;
        margin-top: 15px;
        overflow-x: auto;
        padding-bottom: 5px;
    }

    .img-thumbnail-custom {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 10px;
        cursor: pointer;
        opacity: 0.6;
        transition: all 0.3s;
        border: 2px solid transparent;
    }

        .img-thumbnail-custom:hover, .img-thumbnail-custom.active {
            opacity: 1;
            border-color: #ff6b6b; /* Viền màu cam đỏ khi chọn */
            transform: translateY(-3px);
        }

    /* Thông tin sản phẩm */
    .product-title {
        font-family: 'Nunito', sans-serif;
        font-weight: 800;
        color: #2d3436;
    }

    .product-price {
        color: #d63031; /* Màu đỏ giá tiền */
        font-size: 2rem;
        font-weight: bold;
    }

    /* Card sản phẩm liên quan (Đồng bộ với trang chủ) */
    .related-card {
        transition: transform 0.3s;
        border: none;
        border-radius: 12px;
        overflow: hidden;
    }

        .related-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
</style>

<nav aria-label="breadcrumb" class="mt-3 mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
        <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Thực đơn</a></li>
        <li class="breadcrumb-item active text-primary fw-bold" aria-current="page">@Model.TenMon</li>
    </ol>
</nav>

<div class="row g-5">
    <div class="col-lg-5 col-md-6">
        <div class="product-gallery sticky-top" style="top: 90px; z-index: 1;">
            <div class="main-image-container">
                <img id="mainImage" src="@Url.Content("~/Content/Images/"+Model.AnhDaiDien)"
                     alt="@Model.TenMon">
                <div class="position-absolute top-0 start-0 m-3">
                    <span class="badge bg-danger rounded-pill px-3 py-2">Hot</span>
                </div>
            </div>

            <div class="thumb-wrapper custom-scrollbar">
                <img class="img-thumbnail-custom active"
                     src="@Url.Content("~/Content/Images/"+Model.AnhDaiDien)"
                     data-full-src="@Url.Content("~/Content/Images/"+Model.AnhDaiDien)">

                @if (Model.tblHinhAnhs != null)
                {
                    foreach (var item in Model.tblHinhAnhs)
                    {
                        <img class="img-thumbnail-custom"
                             src="@Url.Content("~/Content/Images/"+item.TenHinh)"
                             data-full-src="@Url.Content("~/Content/Images/"+item.TenHinh)">
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7 col-md-6">
        <h2 class="product-title display-6">@Model.TenMon</h2>

        <div class="mb-3 text-warning small">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
            <span class="text-muted ms-2">(128 đánh giá)</span>
        </div>

        <div class="product-price mb-3">
            @Html.FormatValue(Model.DonGia, "{0:#,###}") <sup class="fs-5 text-muted">đ</sup>
        </div>

        <p class="lead text-secondary" style="font-size: 1rem; line-height: 1.8;">
            @Model.MoTa
        </p>

        <div class="row mb-4 g-2">
            <div class="col-6 col-sm-4">
                <div class="d-flex align-items-center gap-2 p-2 border rounded bg-light">
                    <i class="fas fa-check-circle text-success"></i> <span class="small fw-bold">An toàn vệ sinh</span>
                </div>
            </div>
            <div class="col-6 col-sm-4">
                <div class="d-flex align-items-center gap-2 p-2 border rounded bg-light">
                    <i class="fas fa-truck text-primary"></i> <span class="small fw-bold">Giao hàng nhanh</span>
                </div>
            </div>
            <div class="col-6 col-sm-4">
                <div class="d-flex align-items-center gap-2 p-2 border rounded bg-light">
                    <i class="fas fa-thumbs-up text-warning"></i> <span class="small fw-bold">Hương vị chuẩn</span>
                </div>
            </div>
        </div>

        <div class="d-flex gap-3 mt-4">
            <a href="@Url.Action("AddToCart", "Cart", new { id = Model.MaMon, strURL = Request.Url.ToString() })"
               class="btn btn-danger btn-lg rounded-pill px-5 fw-bold shadow-sm flex-grow-1 flex-md-grow-0">
                <i class="fas fa-shopping-basket me-2"></i> THÊM VÀO GIỎ
            </a>

            <button class="btn btn-outline-secondary btn-lg rounded-circle" title="Yêu thích">
                <i class="far fa-heart"></i>
            </button>
        </div>

        <hr class="my-4 text-muted opacity-25">

        <div class="small text-muted">
            <strong>Danh mục:</strong>
            @if (Model.tblLoaiMon != null)
            {
                <span class="text-primary">@Model.tblLoaiMon.TenLoai</span>
            }
            else
            { <span>Đang cập nhật</span>}
            <br>
            <strong>Nhà cung cấp:</strong>
            @if (Model.tblNCC != null)
            {
                <span>@Model.tblNCC.TenNCC</span>
            }
        </div>
    </div>
</div>

<div class="mt-5 pt-4 border-top">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-dark border-start border-4 border-warning ps-3">Có thể bạn sẽ thích</h4>
        <a href="/" class="text-decoration-none">Xem thực đơn <i class="fas fa-arrow-right"></i></a>
    </div>

    <div class="row row-cols-2 row-cols-md-4 g-4">
        @foreach (var item in (IEnumerable<tblMonAn>)ViewBag.SPLQ)
        {
            <div class="col">
                <div class="card related-card h-100 shadow-sm">
                    <div class="position-relative" style="height: 180px; overflow: hidden;">
                        <img src="@Url.Content("~/Content/Images/"+item.AnhDaiDien)" class="w-100 h-100 object-fit-cover" alt="@item.TenMon" style="object-fit: cover;">
                    </div>
                    <div class="card-body">
                        <h6 class="card-title text-truncate fw-bold">@item.TenMon</h6>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="text-danger fw-bold">@Html.FormatValue(item.DonGia, "{0:#,###}") đ</span>
                            <a href="@Url.Action("Detail", "Home", new { id = item.MaMon})" class="btn btn-sm btn-outline-primary rounded-pill">
                                <i class="fas fa-eye"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            // Hiệu ứng chuyển ảnh
            $(".img-thumbnail-custom").on("click", function () {
                var $this = $(this);
                var newSrc = $this.data("full-src");
                var $mainImg = $("#mainImage");

                // Nếu ảnh đang chọn rồi thì không làm gì
                if ($this.hasClass("active")) return;

                // 1. Fade Out ảnh cũ
                $mainImg.fadeOut(200, function () {
                    // 2. Đổi src
                    $(this).attr("src", newSrc);
                    // 3. Fade In ảnh mới
                }).fadeIn(200);

                // Xử lý class active cho thumbnail
                $(".img-thumbnail-custom").removeClass("active");
                $this.addClass("active");
            });
        });
    </script>
}