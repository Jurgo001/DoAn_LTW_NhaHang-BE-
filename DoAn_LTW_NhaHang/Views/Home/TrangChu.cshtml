@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8">
    <title>Nhà Hàng Ngon - Hương Vị Việt</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="nhà hàng ngon, ẩm thực việt, đặt bàn" name="keywords">
    <meta content="Nhà hàng Ngon mang đến trải nghiệm ẩm thực tuyệt vời nhất." name="description">

    <link href="img/favicon.ico" rel="icon">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600&family=Nunito:wght@600;700;800&family=Pacifico&display=swap" rel="stylesheet">

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <link href="~/TrangChu/lib/animate/animate.min.css" rel="stylesheet">
    <link href="~/TrangChu/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="~/TrangChu/lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />

    <link href="~/TrangChu/css/bootstrap.min.css" rel="stylesheet">

    <link href="~/TrangChu/css/style.css" rel="stylesheet">

    <style>
        :root {
            --primary: #ff6b6b; /* Pink color matching your other pages */
            --light: #F1F8FF;
            --dark: #0F172B;
        }

        .text-primary {
            color: var(--primary) !important;
        }

        .btn-primary {
            color: #FFFFFF;
            background-color: var(--primary);
            border-color: var(--primary);
        }

            .btn-primary:hover {
                color: #FFFFFF;
                background-color: #ff5252;
                border-color: #ff5252;
            }

        .btn-outline-light:hover {
            color: var(--primary);
            border-color: #FFFFFF;
        }

        .navbar-dark .navbar-nav .nav-link.active, .navbar-dark .navbar-nav .nav-link:hover {
            color: var(--primary);
        }

        .service-item:hover {
            background: var(--primary);
        }

            .service-item:hover * {
                color: #FFFFFF !important;
            }

        .nav-pills .nav-item .active {
            border-bottom: 2px solid var(--primary);
        }
    </style>
</head>

<body>
    <div class="container-xxl bg-white p-0">
        <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                <span class="sr-only">Đang tải...</span>
            </div>
        </div>
        <div class="container-xxl position-relative p-0">
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4 px-lg-5 py-3 py-lg-0">
                <a href="@Url.Action("Index","Home")" class="navbar-brand p-0">
                    <h1 class="text-primary m-0"><i class="fa fa-utensils me-3"></i>Nhà Hàng Ngon</h1>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                    <span class="fa fa-bars"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <div class="navbar-nav ms-auto py-0 pe-4">
                        <a href="@Url.Action("TrangChu","Home")" class="nav-item nav-link active">Trang Chủ</a>
                        <a href="@Url.Action("Index","Home")" class="nav-item nav-link">Thực Đơn</a>
                        <a href="#about" class="nav-item nav-link">Giới Thiệu</a>
                        <a href="#service" class="nav-item nav-link">Dịch Vụ</a>
                        <a class="nav-item nav-link" href="@Url.Action("LienHe", "Home")">Liên hệ</a>

                        @if (Session["User"] != null)
                        {
                            <a href="@Url.Action("LichSuDonHang","User")" class="nav-item nav-link">Lịch sử đơn</a>
                        }
                    </div>

                    <div class="d-flex align-items-center">
                        @if (Session["User"] == null)
                        {
                            <a href="@Url.Action("Login","User")" class="btn btn-primary py-2 px-4 me-2">Đăng Nhập</a>
                        }
                        else
                        {
                            // Nếu đã đăng nhập thì hiện tên + menu con
                            var user = Session["User"] as DoAn_LTW_NhaHang.tblKhachHang;
                            <div class="nav-item dropdown">
                                <a href="#" class="nav-link dropdown-toggle text-white fw-bold" data-bs-toggle="dropdown" style="padding-right: 0;">
                                    @(user == null ? "Khách" : user.TenKH)
                                </a>
                                <div class="dropdown-menu m-0">
                                    <a href="@Url.Action("HoSoCaNhan", "User")" class="dropdown-item">Hồ sơ cá nhân</a>
                                    <a href="@Url.Action("Logout","User")" class="dropdown-item text-danger">Đăng xuất</a>
                                </div>
                            </div>
                        }

                        <a href="#book-a-table" class="btn btn-outline-primary py-2 px-4 ms-3">Đặt bàn</a>
                    </div>
                </div>
            </nav>

            <div class="container-xxl py-5 bg-dark hero-header mb-5">
                <div class="container my-5 py-5">

                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                            <i class="fas fa-check-circle me-2"></i> @TempData["Message"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    <div class="row align-items-center g-5">
                        <div class="col-lg-6 text-center text-lg-start">
                            <h1 class="display-3 text-white animated slideInLeft">Thưởng Thức<br>Hương Vị Tuyệt Hảo</h1>
                            <p class="text-white animated slideInLeft mb-4 pb-2">Hãy tận hưởng những món ăn thơm ngon. Chúng tôi mang đến cho bạn hương vị tuyệt vời, phong phú và chất lượng, được chế biến với sự chăm chút để mang lại trải nghiệm ẩm thực trọn vẹn nhất.</p>
                            <a href="#book-a-table" class="btn btn-primary py-sm-3 px-sm-5 me-3 animated slideInLeft">Đặt bàn</a>
                        </div>
                        <div class="col-lg-6 text-center text-lg-end overflow-hidden">
                            <img class="img-fluid" src="~/TrangChu/img/hero.png" alt="">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-xxl py-5" id="service">
            <div class="container">
                <div class="row g-4">
                    <div class="col-lg-3 col-sm-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="service-item rounded pt-3">
                            <div class="p-4">
                                <i class="fa fa-3x fa-user-tie text-primary mb-4"></i>
                                <h5>Đầu Bếp Hàng Đầu</h5>
                                <p>Đội ngũ đầu bếp tài năng với kinh nghiệm lâu năm, tận tâm trong từng món ăn.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6 wow fadeInUp" data-wow-delay="0.3s">
                        <div class="service-item rounded pt-3">
                            <div class="p-4">
                                <i class="fa fa-3x fa-utensils text-primary mb-4"></i>
                                <h5>Thực Phẩm Sạch</h5>
                                <p>Nguyên liệu tươi ngon, được chọn lọc kỹ lưỡng mỗi ngày.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6 wow fadeInUp" data-wow-delay="0.5s">
                        <div class="service-item rounded pt-3">
                            <div class="p-4">
                                <i class="fa fa-3x fa-cart-plus text-primary mb-4"></i>
                                <h5>Đặt Hàng Online</h5>
                                <p>Dễ dàng chọn món và đặt hàng trực tuyến nhanh chóng.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6 wow fadeInUp" data-wow-delay="0.7s">
                        <div class="service-item rounded pt-3">
                            <div class="p-4">
                                <i class="fa fa-3x fa-headset text-primary mb-4"></i>
                                <h5>Hỗ Trợ 24/7</h5>
                                <p>Chúng tôi luôn sẵn sàng lắng nghe và phục vụ bạn.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-xxl py-5" id="about">
            <div class="container">
                <div class="row g-5 align-items-center">
                    <div class="col-lg-6">
                        <div class="row g-3">
                            <div class="col-6 text-start">
                                <img class="img-fluid rounded w-100 wow zoomIn" data-wow-delay="0.1s" src="~/TrangChu/img/about-1.jpg">
                            </div>
                            <div class="col-6 text-start">
                                <img class="img-fluid rounded w-75 wow zoomIn" data-wow-delay="0.3s" src="~/TrangChu/img/about-2.jpg" style="margin-top: 25%;">
                            </div>
                            <div class="col-6 text-end">
                                <img class="img-fluid rounded w-75 wow zoomIn" data-wow-delay="0.5s" src="~/TrangChu/img/about-3.jpg">
                            </div>
                            <div class="col-6 text-end">
                                <img class="img-fluid rounded w-100 wow zoomIn" data-wow-delay="0.7s" src="~/TrangChu/img/about-4.jpg">
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <h5 class="section-title ff-secondary text-start text-primary fw-normal">Về Chúng Tôi</h5>
                        <h1 class="mb-4">Chào mừng đến với <i class="fa fa-utensils text-primary me-2"></i>Nhà Hàng Ngon</h1>
                        <p class="mb-4">Chúng tôi mang đến cho bạn không gian ẩm thực tinh tế với những món ăn được chế biến từ nguyên liệu chất lượng. Tại đây, bạn sẽ tận hưởng hương vị tuyệt vời cùng sự phục vụ tận tâm.</p>
                        <div class="row g-4 mb-4">
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center border-start border-5 border-primary px-3">
                                    <h1 class="flex-shrink-0 display-5 text-primary mb-0" data-toggle="counter-up">15</h1>
                                    <div class="ps-4">
                                        <p class="mb-0">Năm</p>
                                        <h6 class="text-uppercase mb-0">Kinh nghiệm</h6>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center border-start border-5 border-primary px-3">
                                    <h1 class="flex-shrink-0 display-5 text-primary mb-0" data-toggle="counter-up">50</h1>
                                    <div class="ps-4">
                                        <p class="mb-0">Đầu bếp</p>
                                        <h6 class="text-uppercase mb-0">Nổi tiếng</h6>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <a class="btn btn-primary py-3 px-5 mt-2" href="">Xem Chi Tiết</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-xxl py-5">
            <div class="container">
                <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
                    <h5 class="section-title ff-secondary text-center text-primary fw-normal">Thực Đơn</h5>
                    <h1 class="mb-5">Món Ăn Nổi Bật</h1>
                </div>
                <div class="tab-class text-center wow fadeInUp" data-wow-delay="0.1s">

                    @{
                        // Lấy dữ liệu từ ViewBag
                        var danhSachLoai = ViewBag.DanhSachLoai as List<DoAn_LTW_NhaHang.tblLoaiMon>;
                        var topMonAn = ViewBag.TopMonAn as List<DoAn_LTW_NhaHang.Controllers.HomeController.MonAnViewModel>;

                        // --- BƯỚC 1: TẠO TAB NAVIGATION ---
                        int tabIndex = 1;

                        if (danhSachLoai != null && topMonAn != null && topMonAn.Any())
                        {
                            <ul class="nav nav-pills d-inline-flex justify-content-center border-bottom mb-5">
                                @foreach (var loai in danhSachLoai)
                                {
                                    // Chỉ tạo tab nếu loại món đó có trong danh sách top món ăn
                                    if (topMonAn.Any(m => m.MaLoai == loai.MaLoai))
                                    {
                                        <li class="nav-item">
                                            <a class="d-flex align-items-center text-start mx-3 @(tabIndex == 1 ? "ms-0 active" : "") pb-3"
                                               data-bs-toggle="pill"
                                               href="#tab-@tabIndex">
                                                <i class="fa fa-utensils fa-2x text-primary"></i>
                                                <div class="ps-3">
                                                    <small class="text-body">@loai.TenLoai</small>
                                                    <h6 class="mt-n1 mb-0">@loai.TenLoai</h6>
                                                </div>
                                            </a>
                                        </li>
                                        tabIndex++;
                                    }
                                }
                            </ul>

                            // --- BƯỚC 2: TẠO TAB CONTENT (NỘI DUNG MÓN ĂN) ---
                            <div class="tab-content">
                                @{ tabIndex = 1; }
                                @foreach (var loai in danhSachLoai)
                                {
                                    // Lấy danh sách món ăn Top bán chạy thuộc loại hiện tại
                                    var monAnTheoLoai = topMonAn.Where(m => m.MaLoai == loai.MaLoai).ToList();

                                    if (monAnTheoLoai.Any())
                                    {
                                        <div id="tab-@tabIndex" class="tab-pane fade show p-0 @(tabIndex == 1 ? "active" : "")">
                                            <div class="row g-4">
                                                @foreach (var mon in monAnTheoLoai.OrderByDescending(m => m.TongSoLuongBan))
                                                {
                                                    <div class="col-lg-6">
                                                        <div class="d-flex align-items-center">
                                                            <img class="flex-shrink-0 img-fluid rounded"
                                                                 src="@Url.Content("~/Content/Images/" + mon.AnhDaiDien)"
                                                                 alt="@mon.TenMon"
                                                                 style="width: 80px; height: 80px; object-fit: cover;">
                                                            <div class="w-100 d-flex flex-column text-start ps-4">
                                                                <h5 class="d-flex justify-content-between border-bottom pb-2">
                                                                    <span>@mon.TenMon</span>
                                                                    @(mon.DonGia.HasValue ? mon.DonGia.Value.ToString("N0") : "0") đ
                                                                </h5>
                                                                <small class="fst-italic">@mon.MoTa</small>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                        tabIndex++;
                                    }
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-center text-muted fs-5">Chưa có đủ dữ liệu để thống kê món ăn nổi bật.</p>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="container-xxl py-5 px-0 wow fadeInUp" data-wow-delay="0.1s" id="book-a-table">
            <div class="row g-0">
                <div class="col-md-6">
                    <div class="video">
                        <button type="button" class="btn-play" data-bs-toggle="modal" data-src="https://www.youtube.com/embed/WW0SLuX8HsI" data-bs-target="#videoModal">
                            <span></span>
                        </button>
                    </div>
                </div>
                <div class="col-md-6 bg-dark d-flex align-items-center">
                    <div class="p-5 wow fadeInUp" data-wow-delay="0.2s">
                        <h5 class="section-title ff-secondary text-start text-primary fw-normal">Đặt Bàn</h5>
                        <h1 class="text-white mb-4">Giữ Chỗ Trực Tuyến</h1>

                        @using (Html.BeginForm("DatBan", "Home", FormMethod.Post))
                        {
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="name" name="TenKhachHang" placeholder="Tên của bạn" required>
                                        <label for="name">Tên của bạn</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="email" class="form-control" id="email" name="Email" placeholder="Email của bạn">
                                        <label for="email">Email của bạn</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="datetime-local" class="form-control" id="datetime" name="ThoiGian" placeholder="Ngày & Giờ" required />
                                        <label for="datetime">Ngày & Giờ hẹn</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <select class="form-select" id="select1" name="SoNguoi">
                                            <option value="1">1 người</option>
                                            <option value="2">2 người</option>
                                            <option value="3">3 người</option>
                                            <option value="4">4 người</option>
                                            <option value="5+">Trên 5 người</option>
                                        </select>
                                        <label for="select1">Số khách</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-floating">
                                        <textarea class="form-control" placeholder="Yêu cầu đặc biệt" id="message" name="GhiChu" style="height: 100px"></textarea>
                                        <label for="message">Ghi chú thêm</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-primary w-100 py-3" type="submit">Xác Nhận Đặt Bàn</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="videoModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content rounded-0">
                    <div class="modal-header">
                        <h5 class="modal-title" id="exampleModalLabel">Video Giới Thiệu</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="ratio ratio-16x9">
                            <iframe class="embed-responsive-item" src="" id="video" allowfullscreen allowscriptaccess="always" allow="autoplay"></iframe>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-xxl pt-5 pb-3">
            <div class="container">
                <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
                    <h5 class="section-title ff-secondary text-center text-primary fw-normal">Đội Ngũ</h5>
                    <h1 class="mb-5">Đầu Bếp Hàng Đầu</h1>
                </div>
                <div class="row g-4">
                    <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="team-item text-center rounded overflow-hidden">
                            <div class="rounded-circle overflow-hidden m-4">
                                <img class="img-fluid" src="~/TrangChu/img/team-1.jpg" alt="">
                            </div>
                            <h5 class="mb-0">Gordon Ramsay</h5>
                            <small>Bếp Trưởng</small>
                            <div class="d-flex justify-content-center mt-3">
                                <a class="btn btn-square btn-primary mx-1" href="https://www.facebook.com/login/"><i class="fab fa-facebook-f"></i></a>
                                <a class="btn btn-square btn-primary mx-1" href="https://www.tiktok.com/login"><i class="fab fa-twitter"></i></a>
                                <a class="btn btn-square btn-primary mx-1" href="https://www.instagram.com/accounts/login/"><i class="fab fa-instagram"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                        <div class="team-item text-center rounded overflow-hidden">
                            <div class="rounded-circle overflow-hidden m-4">
                                <img class="img-fluid" src="~/TrangChu/img/team-2.jpg" alt="">
                            </div>
                            <h5 class="mb-0">Jamie Oliver</h5>
                            <small>Bếp Phó</small>
                            <div class="d-flex justify-content-center mt-3">
                                <a class="btn btn-square btn-primary mx-1" href="https://www.facebook.com/login/"><i class="fab fa-facebook-f"></i></a>
                                <a class="btn btn-square btn-primary mx-1" href="https://www.tiktok.com/login"><i class="fab fa-twitter"></i></a>
                                <a class="btn btn-square btn-primary mx-1" href="https://www.instagram.com/accounts/login/"><i class="fab fa-instagram"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-xxl py-5 wow fadeInUp" data-wow-delay="0.1s">
            <div class="container">
                <div class="text-center">
                    <h5 class="section-title ff-secondary text-center text-primary fw-normal">Đánh Giá</h5>
                    <h1 class="mb-5">Khách Hàng Nói Gì Về Chúng Tôi!</h1>
                </div>
                <div class="owl-carousel testimonial-carousel">
                    <div class="testimonial-item bg-transparent border rounded p-4">
                        <i class="fa fa-quote-left fa-2x text-primary mb-3"></i>
                        <p>Lần đầu ghé ăn thử, wow nha! Đồ ăn ở nhà hàng rất hợp vị, giá cả phải chăng, không gian sang trọng.</p>
                        <div class="d-flex align-items-center">
                            <img class="img-fluid flex-shrink-0 rounded-circle" src="~/TrangChu/img/testimonial-1.jpg" style="width: 50px; height: 50px;">
                            <div class="ps-3">
                                <h5 class="mb-1">Thanh Nhã</h5>
                                <small>Thực khách</small>
                            </div>
                        </div>
                    </div>
                    <div class="testimonial-item bg-transparent border rounded p-4">
                        <i class="fa fa-quote-left fa-2x text-primary mb-3"></i>
