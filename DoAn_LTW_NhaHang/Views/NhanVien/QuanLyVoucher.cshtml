@model IEnumerable<DoAn_LTW_NhaHang.tblVoucher>
@{
    ViewBag.Title = "Quản lý Voucher";
    Layout = "~/Views/Shared/_LayoutBoss.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark"><i class="fas fa-ticket-alt text-warning me-2"></i>Quản Lý Voucher</h3>
        <a href="@Url.Action("ThemVoucher")" class="btn btn-success rounded-pill px-4 shadow-sm">
            <i class="fas fa-plus me-1"></i> Tạo Voucher Mới
        </a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm alert-dismissible fade show"><i class="fas fa-check-circle me-2"></i> @TempData["Message"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm alert-dismissible fade show"><i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="ps-4 py-3">Tên Voucher</th>
                        <th>Giá Trị</th>
                        <th>Điểm Đổi</th>
                        <th>Số Lượng</th>
                        <th>Hạn Dùng</th>
                        <th class="text-center">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            bool hetHan = item.NgayHetHan < DateTime.Now;
                            <tr class="@(hetHan ? "table-secondary opacity-75" : "")">
                                <td class="ps-4 fw-bold">@item.TenVoucher</td>
                                <td class="text-success fw-bold">@string.Format("{0:N0} đ", item.GiaTri)</td>
                                <td class="text-warning fw-bold">@item.DiemDoi</td>
                                <td>
                                    @if (item.SoLuong > 0)
                                    {<span class="badge bg-primary">@item.SoLuong</span> }
                                else
                                { <span class="badge bg-danger">Hết hàng</span>}
                                </td>
                                <td>
                                    @string.Format("{0:dd/MM/yyyy}", item.NgayHetHan)
                                    @if (hetHan)
                                    {<small class="text-danger d-block">(Đã hết hạn)</small>}
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("SuaVoucher", new { id = item.MaVoucher })" class="btn btn-outline-primary btn-sm rounded-circle me-1"><i class="fas fa-pen"></i></a>
                                    <a href="@Url.Action("XoaVoucher", new { id = item.MaVoucher })" class="btn btn-outline-danger btn-sm rounded-circle" onclick="return confirm('Bạn có chắc muốn xóa voucher này?');"><i class="fas fa-trash-alt"></i></a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted">Chưa có voucher nào!</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>