@model DoAn_LTW_NhaHang.tblVoucher

@{
    ViewBag.Title = "Cập nhật Voucher";
    Layout = "~/Views/Shared/_LayoutBoss.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="card-header bg-gradient bg-warning text-dark p-4">
                <h5 class="m-0 fw-bold text-uppercase">
                    <i class="fas fa-ticket-alt me-2"></i> Cập nhật Voucher
                </h5>
                <small>Đang chỉnh sửa: <b>@Model.TenVoucher</b></small>
            </div>

            <div class="card-body p-5 bg-light">
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                    @Html.HiddenFor(model => model.MaVoucher)

                    <div class="form-floating mb-3">
                        @Html.EditorFor(model => model.TenVoucher, new { htmlAttributes = new { @class = "form-control", placeholder = "Tên voucher", required = "required" } })
                        <label>Tên Voucher</label>
                        @Html.ValidationMessageFor(model => model.TenVoucher, "", new { @class = "text-danger" })
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                @Html.EditorFor(model => model.GiaTri, new { htmlAttributes = new { @class = "form-control", type = "number", placeholder = "Giá trị" } })
                                <label>Giá trị (VNĐ)</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                @Html.EditorFor(model => model.DiemDoi, new { htmlAttributes = new { @class = "form-control", type = "number", placeholder = "Điểm đổi" } })
                                <label>Điểm cần đổi</label>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="form-floating">
                                @Html.EditorFor(model => model.SoLuong, new { htmlAttributes = new { @class = "form-control", type = "number", placeholder = "Số lượng" } })
                                <label>Số lượng còn lại</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                @Html.TextBoxFor(model => model.NgayHetHan, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                <label>Ngày hết hạn</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between pt-3 border-top">
                        <a href="@Url.Action("QuanLyVoucher")" class="btn btn-outline-secondary px-4 rounded-pill">
                            <i class="fas fa-arrow-left me-2"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-warning px-5 rounded-pill fw-bold shadow-sm">
                            <i class="fas fa-save me-2"></i> Lưu Thay Đổi
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>