@model DoAn_LTW_NhaHang.tblKhachHang
@{
    ViewBag.Title = "Thêm khách hàng";
    Layout = "~/Views/Shared/_LayoutBoss.cshtml";
}

<div class="card shadow-sm w-75 mx-auto">
    <div class="card-header bg-primary text-white fw-bold">
        <i class="fas fa-user-plus"></i> THÊM KHÁCH HÀNG MỚI
    </div>
    <div class="card-body">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="row g-3">
                <div class="col-md-6">
                    <label>Họ và tên</label>
                    @Html.EditorFor(model => model.TenKH, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                </div>
                <div class="col-md-6">
                    <label>Số điện thoại</label>
                    @Html.EditorFor(model => model.DienThoai, new { htmlAttributes = new { @class = "form-control" } })
                </div>
                <div class="col-12">
                    <label>Địa chỉ</label>
                    @Html.EditorFor(model => model.DiaChi, new { htmlAttributes = new { @class = "form-control" } })
                </div>
                <div class="col-md-6">
                    <label>Email (Đăng nhập)</label>
                    @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control", required = "required", type = "email" } })
                    @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-6">
                    <label>Mật khẩu</label>
                    @Html.EditorFor(model => model.MatKhau, new { htmlAttributes = new { @class = "form-control", required = "required", type = "password" } })
                </div>
            </div>

            <div class="mt-4 text-end">
                <a href="@Url.Action("QuanLyKhachHang")" class="btn btn-secondary me-2">Hủy bỏ</a>
                <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save"></i> Lưu lại</button>
            </div>
        }
    </div>
</div>