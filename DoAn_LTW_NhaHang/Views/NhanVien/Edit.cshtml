@model DoAn_LTW_NhaHang.tblNhanVien

@{
    ViewBag.Title = "Cập nhật nhân viên";
    Layout = "~/Views/Shared/_LayoutBoss.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-lg border-0 rounded-4">

            <div class="card-header bg-warning text-dark p-4">
                <h5 class="m-0 fw-bold text-uppercase">
                    <i class="fas fa-user-edit me-2"></i> Cập nhật hồ sơ nhân sự
                </h5>
                <small>Đang chỉnh sửa: <b>@Model.TenNV</b></small>
            </div>

            <div class="card-body p-5 bg-light">
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.MaNV) @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                @Html.EditorFor(model => model.TenNV, new { htmlAttributes = new { @class = "form-control", placeholder = "Họ tên", required = "required" } })
                                <label>Họ và tên</label>
                            </div>

                            <div class="form-floating mb-3">
                                @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control", placeholder = "Email", required = "required" } })
                                <label>Email (Tài khoản)</label>
                            </div>

                            <div class="form-group mb-3">
                                <label class="fw-bold text-muted small mb-1">Giới tính</label>
                                <select name="GioiTinh" class="form-select p-3">
                                    <option value="Nam" @(Model.GioiTinh == "Nam" ? "selected" : "")>Nam</option>
                                    <option value="Nữ" @(Model.GioiTinh == "Nữ" ? "selected" : "")>Nữ</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                @Html.EditorFor(model => model.NamSinh, new { htmlAttributes = new { @class = "form-control", type = "number", placeholder = "Năm sinh" } })
                                <label>Năm sinh</label>
                            </div>

                            <div class="form-group mb-3">
                                <label class="fw-bold text-muted small mb-1">Chức vụ / Quyền hạn</label>
                                @Html.DropDownList("VaiTro", null, htmlAttributes: new { @class = "form-select p-3" })
                            </div>

                            <div class="form-floating mb-3">
                                <input type="password" name="MatKhau" class="form-control" placeholder="Mật khẩu mới" />
                                <label class="text-danger">Mật khẩu mới (Để trống nếu không đổi)</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary px-4 rounded-pill">
                            <i class="fas fa-arrow-left me-2"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-warning px-5 rounded-pill fw-bold shadow-sm text-dark">
                            <i class="fas fa-save me-2"></i> Lưu Hồ Sơ
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>