@model DoAn_LTW_NhaHang.tblNhanVien
@{
    ViewBag.Title = "Tuyển dụng nhân sự";
    Layout = "~/Views/Shared/_LayoutBoss.cshtml";
}

<style>
    /* CSS Riêng cho Form Boss */
    .card-boss {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .card-header-boss {
        background: linear-gradient(45deg, #1e293b, #334155);
        color: #f59e0b; /* Màu vàng */
        padding: 20px;
        border-bottom: 2px solid #f59e0b;
    }

    .form-label-boss {
        font-weight: 600;
        color: #475569;
        font-size: 0.9rem;
        margin-bottom: 8px;
    }

    .input-group-text {
        background-color: #f8fafc;
        border-right: none;
        color: #64748b;
    }

    .form-control {
        border-left: none;
        background-color: #f8fafc;
        padding: 12px;
        font-size: 0.95rem;
    }

        .form-control:focus {
            background-color: #fff;
            box-shadow: none;
            border-color: #cbd5e1;
            border-left: none;
        }

    /* Hiệu ứng viền khi focus cả cụm input */
    .input-group:focus-within {
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.2);
        border-radius: 6px;
    }

        .input-group:focus-within .input-group-text {
            border-color: #f59e0b;
            color: #f59e0b;
        }

        .input-group:focus-within .form-control {
            border-color: #f59e0b;
        }

    .btn-boss-save {
        background: linear-gradient(45deg, #f59e0b, #d97706);
        border: none;
        color: white;
        padding: 12px 30px;
        font-weight: 600;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
        transition: all 0.3s;
    }

        .btn-boss-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(245, 158, 11, 0.4);
            color: white;
        }
</style>

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card card-boss">
            <div class="card-header-boss d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="m-0 fw-bold text-uppercase"><i class="fas fa-user-plus me-2"></i> Hồ sơ nhân viên mới</h5>
                    <small class="text-white-50">Nhập thông tin chính xác để cấp quyền truy cập.</small>
                </div>
                <a href="@Url.Action("Index")" class="btn btn-outline-light btn-sm">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
            </div>

            <div class="card-body p-5">
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label class="form-label-boss">Họ và Tên</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                                    @Html.EditorFor(model => model.TenNV, new { htmlAttributes = new { @class = "form-control", placeholder = "Nhập họ tên đầy đủ...", required = "required" } })
                                </div>
                                @Html.ValidationMessageFor(model => model.TenNV, "", new { @class = "text-danger small" })
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label-boss">Năm sinh</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-calendar-alt"></i></span>
                                    @Html.EditorFor(model => model.NamSinh, new { htmlAttributes = new { @class = "form-control", type = "number", placeholder = "Ví dụ: 2000" } })
                                </div>
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label-boss">Giới tính</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-venus-mars"></i></span>
                                    <select name="GioiTinh" class="form-control form-select">
                                        <option value="Nam">Nam</option>
                                        <option value="Nữ">Nữ</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label class="form-label-boss">Email (Tài khoản)</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                    @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control", type = "email", placeholder = "nhanvien@nhahang.com", required = "required" } })
                                </div>
                                @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger small" })
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label-boss">Mật khẩu khởi tạo</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                    @Html.EditorFor(model => model.MatKhau, new { htmlAttributes = new { @class = "form-control", type = "password", placeholder = "******", required = "required" } })
                                </div>
                                @Html.ValidationMessageFor(model => model.MatKhau, "", new { @class = "text-danger small" })
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label-boss">Phân quyền chức vụ</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-id-badge"></i></span>
                                    @Html.DropDownList("VaiTro", null, htmlAttributes: new { @class = "form-control form-select" })
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 text-end border-top pt-4">
                        <button type="submit" class="btn btn-boss-save">
                            <i class="fas fa-save me-2"></i> Xác nhận Tuyển dụng
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>